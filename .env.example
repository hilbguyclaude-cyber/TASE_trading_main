# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Email
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_EMAIL=your-email@example.com

# IBKR (Interactive Brokers)
# TRADING_MODE: DRY_RUN (simulated), PAPER (paper trading), LIVE (real money)
TRADING_MODE=DRY_RUN
# IBKR_GATEWAY_HOST: IP of EC2 running IB Gateway (or 127.0.0.1 for local)
IBKR_GATEWAY_HOST=127.0.0.1
# IBKR_CLIENT_ID: Unique client ID (use different IDs for multiple connections)
IBKR_CLIENT_ID=1

# System
SYSTEM_TIMEZONE=Asia/Jerusalem
DASHBOARD_URL=https://your-app.vercel.app
